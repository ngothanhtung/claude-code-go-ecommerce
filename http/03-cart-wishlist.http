@baseUrl = http://localhost:8080
@accessToken = {{loginStorefront.response.body.data.access_token}}
@productId = p1
@secondProductId = p9

### Login first
# @name loginStorefront
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "admin@go-tutorials.local",
  "password": "Admin@123456"
}

### Read cart
# @name getCart
GET {{baseUrl}}/api/v1/cart
Authorization: Bearer {{accessToken}}

### Replace cart
# @name replaceCart
PUT {{baseUrl}}/api/v1/cart
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "items": [
    {"product_id": "{{productId}}", "quantity": 2},
    {"product_id": "{{secondProductId}}", "quantity": 1}
  ]
}

### Read the updated cart
# @name getUpdatedCart
GET {{baseUrl}}/api/v1/cart
Authorization: Bearer {{accessToken}}

### Clear cart (run after order tests if reusing this cart)
# @name clearCart
DELETE {{baseUrl}}/api/v1/cart
Authorization: Bearer {{accessToken}}

### Read wishlist
# @name getWishlist
GET {{baseUrl}}/api/v1/wishlist
Authorization: Bearer {{accessToken}}

### Replace wishlist
# @name replaceWishlist
PUT {{baseUrl}}/api/v1/wishlist
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "product_ids": ["{{productId}}", "{{secondProductId}}"]
}

### Add one product (idempotent)
# @name addWishlistProduct
POST {{baseUrl}}/api/v1/wishlist/{{productId}}
Authorization: Bearer {{accessToken}}

### Remove one product
# @name removeWishlistProduct
DELETE {{baseUrl}}/api/v1/wishlist/{{productId}}
Authorization: Bearer {{accessToken}}

### Read final wishlist
# @name getFinalWishlist
GET {{baseUrl}}/api/v1/wishlist
Authorization: Bearer {{accessToken}}
