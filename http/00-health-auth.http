@baseUrl = http://localhost:8080
@email = manual.auth@example.com
@password = Password123
@accessToken = {{login.response.body.data.access_token}}
@refreshToken = {{login.response.body.data.refresh_token}}

### Liveness
# @name health
GET {{baseUrl}}/healthz

### Readiness (PostgreSQL + Redis)
# @name readiness
GET {{baseUrl}}/readyz

### Register (run once, or change @email before running again)
# @name register
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "email": "{{email}}",
  "name": "Manual Auth User",
  "password": "{{password}}"
}

### Login as the seeded development admin
# @name login
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "admin@go-tutorials.local",
  "password": "Admin@123456"
}

### Read the current user with the access token
# @name me
GET {{baseUrl}}/api/v1/users/me
Authorization: Bearer {{accessToken}}

### Rotate the token pair
# @name refresh
POST {{baseUrl}}/api/v1/auth/refresh
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

### Request a password reset token (development only)
# @name forgotPassword
POST {{baseUrl}}/api/v1/auth/forgot-password
Content-Type: application/json

{
  "email": "{{email}}"
}

### Reset password
### Replace the token with forgotPassword.response.body.data.dev_token.
# @name resetPassword
POST {{baseUrl}}/api/v1/auth/reset-password
Content-Type: application/json

{
  "token": "{{forgotPassword.response.body.data.dev_token}}",
  "new_password": "NewPassword123"
}

### Logout and revoke the refresh token (run last)
# @name logout
POST {{baseUrl}}/api/v1/auth/logout
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}
